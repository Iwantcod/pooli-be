<configuration>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder"/>
    </appender>

    <!--    <logger name="com.pooli" level="DEBUG"/>-->

    <!-- local profile -->
    <springProfile name="local">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

    </springProfile>


    <!-- local 이외 (Docker stdout → Promtail → Loki) -->
    <springProfile name="!local">


        <!-- 배포 환경에서도 시작/실패 원인을 바로 볼 수 있도록 콘솔 출력은 유지한다. -->

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

    </springProfile>

    <springProfile name="traffic">


        <!-- 배포 환경에서도 시작/실패 원인을 바로 볼 수 있도록 콘솔 출력은 유지한다. -->

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

    </springProfile>

</configuration>

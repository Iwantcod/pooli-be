<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pooli.permission.mapper.FamilyLineMapper">

    <resultMap id="familyLineResultMap" type="com.pooli.family.domain.entity.FamilyLine">
        <constructor>
            <arg column="family_id"  javaType="java.lang.Long"/>
            <arg column="line_id"    javaType="java.lang.Long"/>
            <arg column="role"       javaType="com.pooli.family.domain.enums.FamilyRole"/>
            <arg column="is_public"  javaType="java.lang.Boolean"/>
            <arg column="created_at" javaType="java.time.LocalDateTime"/>
            <arg column="updated_at" javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>

    <!-- lineId로 FamilyLine 조회 -->
    <select id="findByLineId" resultMap="familyLineResultMap">
        SELECT family_id, line_id, role, is_public, created_at, updated_at
        FROM FAMILY_LINE
        WHERE line_id = #{lineId}
    </select>

    <!-- familyId + lineId로 FamilyLine 조회 -->
    <select id="findByFamilyIdAndLineId" resultMap="familyLineResultMap">
        SELECT family_id, line_id, role, is_public, created_at, updated_at
        FROM FAMILY_LINE
        WHERE family_id = #{familyId}
          AND line_id = #{lineId}
    </select>

    <!-- 특정 lineId를 가지는 가족 그룹에 속한 모든 lineId 목록 조회 -->
    <select id="findAllFamilyIdByLineId" parameterType="long" resultType="long">
        SELECT line_id
        FROM FAMILY_LINE
        WHERE family_id = (
            SELECT family_id
            FROM FAMILY_LINE
            WHERE line_id = #{lineId}
        );
    </select>

    <!-- 역할 변경 (OWNER <-> MEMBER) -->
    <update id="updateRole">
        UPDATE FAMILY_LINE
        SET role       = #{role},
            updated_at = NOW()
        WHERE family_id = #{familyId}
          AND line_id = #{lineId}
    </update>

</mapper>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pooli.permission.mapper.LineUserPermissionMapper">

    <resultMap id="lineResultMap" type="com.pooli.line.domain.entity.Line">
        <constructor>
            <arg column="line_id"              javaType="java.lang.Long"/>
            <arg column="user_id"              javaType="java.lang.Long"/>
            <arg column="plan_id"              javaType="java.lang.Integer"/>
            <arg column="phone"                javaType="java.lang.String"/>
            <arg column="block_end_at"         javaType="java.time.LocalDateTime"/>
            <arg column="remaining_data"       javaType="java.lang.Long"/>
            <arg column="is_main"              javaType="java.lang.Boolean"/>
            <arg column="created_at"           javaType="java.time.LocalDateTime"/>
            <arg column="deleted_at"           javaType="java.time.LocalDateTime"/>
            <arg column="updated_at"           javaType="java.time.LocalDateTime"/>
            <arg column="individual_threshold" javaType="java.lang.Long"/>
            <arg column="is_threshold_active"  javaType="java.lang.Boolean"/>
        </constructor>
    </resultMap>

    <!-- userId로 메인 회선 조회 -->
    <select id="findMainLineByUserId" resultMap="lineResultMap">
        SELECT line_id, user_id, plan_id, phone, block_end_at, remaining_data,
               is_main, created_at, deleted_at, updated_at,
               individual_threshold, is_threshold_active
        FROM LINE
        WHERE user_id = #{userId}
          AND is_main = true
          AND deleted_at IS NULL
    </select>

</mapper>

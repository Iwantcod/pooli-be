<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pooli.notification.mapper.AlarmHistoryMapper">

    <insert id="insertAlarmHistory">
        INSERT INTO ALARM_HISTORY (
        line_id,
        alarm_code,
        value,
        created_at,
        deleted_at,
        read_at
        )
        VALUES (
        #{lineId},
        #{alarmCode},
        #{value},
        NOW(6),
        NULL,
        NULL
        )
    </insert>

</mapper>
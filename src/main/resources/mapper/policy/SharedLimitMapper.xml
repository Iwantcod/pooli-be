<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pooli.policy.mapper.SharedLimitMapper">
    <resultMap id="sharedLimitResultMap" type="com.pooli.policy.domain.entity.SharedLimit">
        <constructor>
            <arg column="shared_limit_id"  javaType="java.lang.Long"/>
            <arg column="line_id"  javaType="java.lang.Long"/>
            <arg column="shared_data_limit"  javaType="java.lang.Long"/>
            <arg column="is_active"  javaType="java.lang.Boolean"/>
            <arg column="created_at" javaType="java.time.LocalDateTime"/>
            <arg column="deleted_at" javaType="java.time.LocalDateTime"/>
            <arg column="updated_at" javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>

    <!-- 특정 lineId의 삭제 상태가 아닌 SharedLimit 조회 -->
    <select id="getExistSharedLimitByLineId" resultMap="sharedLimitResultMap" parameterType="long">
        SELECT *
        FROM SHARED_LIMIT
        WHERE line_id = #{lineId} AND deleted_at IS NULL;
    </select>

    <!-- 특정 pk의 삭제 상태가 아닌 SharedLimit 조회 -->
    <select id="getExistSharedLimitById" resultMap="sharedLimitResultMap" parameterType="long">
        SELECT *
        FROM SHARED_LIMIT
        WHERE shared_limit_id = #{sharedLimitId}
          AND deleted_at IS NULL;
    </select>

    <!-- 특정 sharedLimitId의 삭제 상태가 아닌 SharedLimit 활성화 상태로 update -->
    <update id="activateSharedLimitBySharedLimitId" parameterType="long">
        UPDATE SHARED_LIMIT
        SET is_active = 1,
            updated_at = now()
        WHERE shared_limit_id = #{sharedLimitId}
          AND deleted_at IS NULL;
    </update>

    <!-- 특정 sharedLimitId의 삭제 상태가 아닌 SharedLimit 비활성화 상태로 update -->
    <update id="deactivateSharedLimitBySharedLimitId" parameterType="long">
        UPDATE SHARED_LIMIT
        SET is_active = 0,
            updated_at = now()
        WHERE shared_limit_id = #{sharedLimitId}
          AND deleted_at IS NULL;
    </update>

    <!-- 특정 sharedLimitId의 삭제 상태가 아닌 SharedLimit 레코드의 shared_data_limit update -->
    <update id="updateSharedDataLimit" parameterType="com.pooli.policy.domain.dto.request.LimitPolicyUpdateReqDto">
        UPDATE SHARED_LIMIT
        SET shared_data_limit = #{policyValue},
            updated_at = now()
        WHERE shared_limit_id = #{limitPolicyId}
          AND deleted_at IS NULL;
    </update>

    <!-- 새 SharedLimit 레코드 insert -->
    <insert id="createSharedLimit"
            parameterType="com.pooli.policy.domain.entity.SharedLimit"
            useGeneratedKeys="true"
            keyProperty="sharedLimitId"
            keyColumn="shared_limit_id">

        INSERT INTO SHARED_LIMIT (line_id,   shared_data_limit,  is_active,   created_at)
                          VALUES (#{lineId}, #{sharedDataLimit}, #{isActive}, now());

    </insert>
</mapper>

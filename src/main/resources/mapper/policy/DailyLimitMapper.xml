<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pooli.policy.mapper.DailyLimitMapper">
    <resultMap id="dailyLimitResultMap" type="com.pooli.policy.domain.entity.DailyLimit">
        <constructor>
            <arg column="daily_limit_id"  javaType="java.lang.Long"/>
            <arg column="line_id"  javaType="java.lang.Long"/>
            <arg column="daily_data_limit"  javaType="java.lang.Long"/>
            <arg column="is_active"  javaType="java.lang.Boolean"/>
            <arg column="created_at" javaType="java.time.LocalDateTime"/>
            <arg column="deleted_at" javaType="java.time.LocalDateTime"/>
            <arg column="updated_at" javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>

    <select id="getDailyLimitByLineId" resultMap="dailyLimitResultMap" parameterType="long">
        SELECT *
        FROM DAILY_LIMIT
        WHERE line_id = #{lineId} AND deleted_at IS NULL;
    </select>
</mapper>
